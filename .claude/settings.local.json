      "Bash(node -e \"JSON.parse\\(require\\('fs'\\).readFileSync\\('src/i18n/translations/en.json','utf8'\\)\\); console.log\\('en.json: valid'\\)\")",
      "Bash(npx next *)",
      "Bash(node -e \"JSON.parse\\(require\\('fs'\\).readFileSync\\('src/i18n/translations/pt.json','utf8'\\)\\); console.log\\('pt.json valid'\\)\")",
      "Bash(node -e \"JSON.parse\\(require\\('fs'\\).readFileSync\\('src/i18n/translations/en.json','utf8'\\)\\); console.log\\('en.json valid'\\)\")"
